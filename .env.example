# API key de pokemontcg.io (OPCIONAL, sube el límite de peticiones).
# Sin clave funciona pero con throttling. Obtén la tuya en https://pokemontcg.io
POKEMONTCG_KEY=

# URL del Cloudflare Worker que hace el scraping (TCGMatch + TCGPlayer).
# Sin esto, /api/prices devolverá 503.
# Ejemplo: https://pkm-prices-worker.<subdomain>.workers.dev
PRICES_BACKEND_URL=
