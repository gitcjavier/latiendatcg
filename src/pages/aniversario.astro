---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Tabs from "../components/Tabs.astro";
import PageTitle from "../components/PageTitle.astro";
import PreventaRow from "../components/PreventaRow.astro";
import { searchAniversario30 } from "../lib/preventas.js";

export const prerender = false;

const sp = Astro.url.searchParams;
const onlyInStock = sp.get("stock") === "1";
const storesParam = (sp.get("stores") ?? "").trim();
const selectedStoreIds = storesParam
  .split(",")
  .map(s => s.trim())
  .filter(Boolean);

let data: any = { total: 0, storesFound: [], storeGroups: [] };
let err: string | null = null;
try {
  data = await searchAniversario30({
    onlyInStock,
    storeIds: selectedStoreIds.length ? selectedStoreIds : null,
  });
} catch (e: any) {
  err = e?.message ?? "Error al buscar productos";
}

const storesFound = data.storesFound ?? [];
const storeGroups = data.storeGroups ?? [];
const total = data.total ?? 0;
const activeStoreIds = new Set<string>(selectedStoreIds);
const tabCount = total > 0 ? total : "00";

// Preserva params actuales aplicando overrides. Null borra la clave.
function buildHref(overrides: Record<string, string | null> = {}) {
  const base: Record<string, string> = {};
  if (onlyInStock) base.stock = "1";
  if (selectedStoreIds.length) base.stores = selectedStoreIds.join(",");
  for (const [k, v] of Object.entries(overrides)) {
    if (v === null || v === "") delete base[k];
    else base[k] = v;
  }
  const qs = new URLSearchParams(base).toString();
  return qs ? `/aniversario?${qs}` : "/aniversario";
}
const hrefToggleStock = () =>
  buildHref({ stock: onlyInStock ? null : "1" });
function hrefToggleStore(id: string) {
  const next = new Set(activeStoreIds);
  if (next.has(id)) next.delete(id); else next.add(id);
  return buildHref({ stores: next.size ? Array.from(next).join(",") : null });
}
const hrefClearStores = () => buildHref({ stores: null });
---

<Layout title="30° Aniversario Pokémon — LaTiendaTCG">
  <Header />
  <Tabs active="aniversario" counts={{ aniversario: tabCount }} />

  <main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 py-10 sm:py-12">
    <PageTitle
      eyebrow="30 años Pokémon TCG"
      title="Aniversario"
      accent="30°"
      meta={total > 0
        ? `${total} producto${total !== 1 ? "s" : ""} · ${storeGroups.length} tienda${storeGroups.length !== 1 ? "s" : ""}`
        : "Escaneando tiendas chilenas"}
    />

    {/* Chips de tiendas — multi-select */}
    {storesFound.length > 0 && (
      <div class="flex flex-wrap items-center gap-2 mb-4">
        <span class="text-[10px] font-bold tracking-[0.14em] uppercase text-ink-400 mr-1">Tiendas</span>
        {storesFound.map((s: any) => {
          const isActive = activeStoreIds.size === 0 || activeStoreIds.has(s.id);
          return (
            <a href={hrefToggleStore(s.id)}
               class={[
                 "inline-flex items-center gap-2 text-xs font-semibold rounded-full border pl-3 pr-1.5 py-1 transition",
                 isActive
                   ? "text-paper bg-ink-900 border-ink-900"
                   : "text-ink-500 bg-paper border-ink-200 hover:border-ink-300",
               ].join(" ")}>
              {s.name}
              <span class={[
                "text-[11px] tabular font-bold rounded-full px-2 py-0.5",
                isActive ? "text-ink-900 bg-paper" : "text-ink-400 bg-ink-100",
              ].join(" ")}>{s.count}</span>
            </a>
          );
        })}
        {activeStoreIds.size > 0 && (
          <a href={hrefClearStores()}
             class="text-[11px] font-semibold text-ink-400 hover:text-ink-700 underline underline-offset-2 ml-1">
            Todas
          </a>
        )}
      </div>
    )}

    {/* Toggle stock */}
    <div class="flex flex-wrap items-center gap-3 mb-8">
      <a href={hrefToggleStock()}
         class={[
           "inline-flex items-center gap-2 text-xs font-bold tracking-[0.06em] uppercase rounded-full border px-3 py-1.5 transition",
           onlyInStock
             ? "text-paper bg-success border-success"
             : "text-ink-700 bg-paper border-ink-200 hover:border-ink-300",
         ].join(" ")}>
        <span class={[
          "w-3.5 h-3.5 grid place-items-center rounded-sm border",
          onlyInStock ? "bg-paper border-paper" : "border-ink-300",
        ].join(" ")}>
          {onlyInStock && (
            <svg class="w-2.5 h-2.5 text-success" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5">
              <path d="M2 6.5l2.5 2.5L10 3.5"></path>
            </svg>
          )}
        </span>
        Solo con stock
      </a>
    </div>

    {err && (
      <div class="text-center py-16 text-ink-400">{err}</div>
    )}

    {!err && total === 0 && (
      <div class="text-center py-24 text-ink-400 max-w-lg mx-auto">
        <p class="text-sm">Todavía no hay muchos productos oficiales del 30° aniversario Pokémon TCG en las tiendas chilenas escaneadas.</p>
        <p class="mt-3 text-xs">Los sets del 30° aniversario (Mega Evolution, White Flare, Black Bolt) llegan en 2026. Esta página se actualizará automáticamente cuando aparezcan las primeras preventas.</p>
        <p class="mt-6 text-xs">
          Mientras, mira otros sets celebratorios en <a href="/productos?q=prismatic+evolutions" class="text-brand font-semibold underline underline-offset-2">Prismatic Evolutions</a> o <a href="/productos?q=151" class="text-brand font-semibold underline underline-offset-2">Pokémon 151</a>.
        </p>
      </div>
    )}

    {!err && total > 0 && (
      <div class="space-y-12">
        {storeGroups.map((g: any) => (
          <section>
            <div class="flex items-baseline justify-between mb-3 pb-2 border-b border-ink-200">
              <h2 class="font-display text-2xl font-bold tracking-tight">
                {g.storeName}
              </h2>
              <p class="text-[11px] font-bold tracking-[0.14em] uppercase text-ink-400">
                {g.products.length} producto{g.products.length !== 1 ? "s" : ""} · desde más barato
              </p>
            </div>
            <div>
              {g.products.map((p: any) => <PreventaRow product={p} />)}
            </div>
          </section>
        ))}
      </div>
    )}
  </main>
</Layout>
