---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Tabs from "../components/Tabs.astro";
import PageTitle from "../components/PageTitle.astro";
import CardItem from "../components/CardItem.astro";
import { searchCardsByName } from "../lib/pokemontcg.js";

export const prerender = false;

const query = (Astro.url.searchParams.get("q") ?? "").trim();

let cards: any[] = [];
let total = 0;
let suggestion: string | null = null;
let err: string | null = null;
if (query && query.length >= 2) {
  try {
    const data = await searchCardsByName(query);
    cards = data.cards ?? [];
    total = data.total ?? cards.length;
    suggestion = data.suggestion ?? null;
  } catch (e: any) {
    err = e?.message ?? "Error al buscar cartas";
  }
}
---

<Layout title={query ? `${query} — LaTiendaTCG` : "LaTiendaTCG"}>
  <Header query={query} />
  <Tabs active="search" counts={{ search: query ? total : "00" }} />

  <main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 py-10 sm:py-12">
    {!query && (
      <div class="text-center py-16 sm:py-24">
        <p class="text-[11px] sm:text-xs font-semibold tracking-[0.18em] uppercase text-brand mb-3 sm:mb-4">
          Comparador de precios
        </p>
        <h1 class="font-display text-[2.25rem] sm:text-5xl md:text-6xl font-bold leading-[1.05] tracking-tight">
          Cartas <span class="text-brand">Pokémon</span><br />en tiempo real
        </h1>
        <p class="mt-5 sm:mt-6 text-ink-500 text-sm sm:text-base px-2">
          TCGMatch.cl · TCGPlayer.com · Tipo de cambio del día
        </p>
        <p class="mt-10 sm:mt-12 inline-flex items-center gap-2 text-xs text-ink-500 border border-ink-200 rounded-full px-4 py-2">
          ↑ Escribe en el buscador para comenzar
        </p>
      </div>
    )}

    {query && err && (
      <div class="text-center py-24">
        <p class="text-xs font-bold tracking-[0.18em] uppercase text-danger mb-4">Error</p>
        <p class="font-display text-3xl font-bold">No se pudo buscar</p>
        <p class="mt-4 text-ink-500 text-sm">{err}</p>
      </div>
    )}

    {query && !err && (
      <>
        <PageTitle
          eyebrow="Resultados"
          title={query.split(" ")[0]}
          accent={query.split(" ").slice(1).join(" ")}
          meta={`${total} resultado${total !== 1 ? "s" : ""}`}
        />

        {cards.length === 0 ? (
          <div class="text-center py-24">
            <p class="text-ink-400">Sin resultados para "{query}"</p>
            {suggestion && (
              <p class="mt-4 text-sm">
                <span class="text-ink-500">¿Quisiste decir</span>{" "}
                <a href={`/?q=${encodeURIComponent(suggestion)}`} class="text-brand font-semibold hover:underline">
                  {suggestion}
                </a>
                <span class="text-ink-500">?</span>
              </p>
            )}
          </div>
        ) : (
          <>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 md:gap-5">
              {cards.map((card) => <CardItem card={card} />)}
            </div>
            <script
              type="application/json"
              id="cards-data"
              set:html={JSON.stringify(cards)}
            />
          </>
        )}
      </>
    )}
  </main>
</Layout>
