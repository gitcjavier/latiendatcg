---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Tabs from "../../components/Tabs.astro";
import PageTitle from "../../components/PageTitle.astro";
import CardItem from "../../components/CardItem.astro";
import { getCardsBySet, getStandardSets } from "../../lib/pokemontcg.js";

export const prerender = false;

const { id } = Astro.params;
if (!id) return Astro.redirect("/ediciones");

let setMeta: any = null;
let cards: any[] = [];
let totalCount = 0;
let hasMore = false;
let err: string | null = null;

try {
  const sets = await getStandardSets();
  setMeta = sets.find((s) => s.id === id) ?? null;
  const data = await getCardsBySet(id, 1);
  cards = data.cards ?? [];
  totalCount = data.totalCount ?? cards.length;
  hasMore = data.hasMore;
} catch (e: any) {
  err = e?.message ?? "Error al cargar la edición";
}

const setName = setMeta?.name ?? id;
const [firstWord, ...rest] = setName.split(" ");
const accent = rest.join(" ");
---

<Layout title={`${setName} — LaTiendaTCG`}>
  <Header />
  <Tabs active="sets" />

  <main class="flex-1 max-w-7xl mx-auto w-full px-6 py-12">
    <a
      href="/ediciones"
      class="inline-flex items-center gap-1.5 text-xs font-bold text-ink-500 hover:text-ink-900 mb-6 transition"
    >
      <svg class="w-3 h-3" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13L5 8l5-5"/></svg>
      EDICIONES
    </a>

    <PageTitle
      eyebrow={setMeta?.series ?? "Edición"}
      title={firstWord}
      accent={accent}
      meta={`${totalCount} cartas`}
    />

    {err && (
      <div class="text-center py-16 text-ink-400">{err}</div>
    )}

    {!err && cards.length === 0 && (
      <div class="text-center py-16 text-ink-400">Cargando…</div>
    )}

    {cards.length > 0 && (
      <>
        <div
          id="cards-grid"
          class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 md:gap-5"
        >
          {cards.map((card) => <CardItem card={card} />)}
        </div>
        <script
          type="application/json"
          id="cards-data"
          set:html={JSON.stringify(cards)}
        />

        {hasMore && (
          <div class="mt-12 text-center">
            <button
              id="loadmore-btn"
              data-set-id={id}
              data-next-page="2"
              class="bg-ink-900 text-paper text-xs font-bold tracking-wide px-8 py-3 rounded-full hover:opacity-85 active:scale-95 transition disabled:opacity-40"
            >
              CARGAR MÁS CARTAS
            </button>
          </div>
        )}
      </>
    )}
  </main>

  <script>
    const btn = document.getElementById("loadmore-btn") as HTMLButtonElement | null;
    if (btn) {
      btn.addEventListener("click", async () => {
        const setId = btn.dataset.setId!;
        const nextPage = parseInt(btn.dataset.nextPage ?? "2", 10);
        btn.disabled = true;
        btn.textContent = "CARGANDO…";
        try {
          const r = await fetch(`/api/sets/${setId}/cards?page=${nextPage}`);
          const data = await r.json();
          const grid = document.getElementById("cards-grid")!;
          for (const c of data.cards ?? []) {
            const a = document.createElement("article");
            a.className = "group relative bg-paper border border-ink-200 rounded-lg overflow-hidden hover:border-ink-300 hover:shadow-[0_8px_24px_rgba(11,11,11,0.06)] transition cursor-pointer";
            a.dataset.cardId = c.id;
            a.dataset.cardName = c.name;
            a.dataset.cardNumber = c.number ?? "";
            a.dataset.cardSet = c.set ?? "";
            const imgSrc = c.images?.small || c.images?.large || "";
            const rar = (c.rarity || "").replace(/Special Illustration Rare/i, "Special Illust.");
            a.innerHTML = `
              <div class="aspect-[367/512] bg-ink-100 relative">
                ${rar ? `<span class="absolute top-3 left-3 text-[10px] font-bold tracking-[0.08em] uppercase bg-paper border border-ink-200 rounded px-2 py-1">${rar}</span>` : ""}
                ${imgSrc ? `<img src="${imgSrc}" alt="${c.name}" loading="lazy" class="absolute inset-0 w-full h-full object-contain" />` : `<div class="absolute inset-0 grid place-items-center text-ink-300 text-xs">—</div>`}
              </div>
              <div class="p-4 border-t border-ink-200">
                <h3 class="font-display font-bold text-[17px] leading-tight tracking-tight truncate">${c.name}</h3>
                <p class="text-[11px] text-ink-400 mt-1 truncate">${c.set ?? ""}${c.number ? " · " + c.number : ""}</p>
              </div>
              <div class="grid grid-cols-2 border-t border-ink-200">
                <div class="px-4 py-3 border-r border-ink-200">
                  <p class="text-[10px] tracking-[0.12em] font-bold text-ink-400">TCGM</p>
                  <p class="font-display text-base font-bold tabular mt-0.5" data-price="tcgm">—</p>
                </div>
                <div class="px-4 py-3">
                  <p class="text-[10px] tracking-[0.12em] font-bold text-ink-400">TCGP</p>
                  <p class="font-display text-base font-bold tabular mt-0.5" data-price="tcgp">—</p>
                </div>
              </div>`;
            grid.appendChild(a);
          }
          if (data.hasMore) {
            btn.dataset.nextPage = String(nextPage + 1);
            btn.disabled = false;
            btn.textContent = "CARGAR MÁS CARTAS";
          } else {
            btn.style.display = "none";
          }
        } catch (e) {
          btn.disabled = false;
          btn.textContent = "REINTENTAR";
        }
      });
    }
  </script>
</Layout>
