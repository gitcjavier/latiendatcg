---
import "../styles/global.css";
import SearchLoader from "../components/SearchLoader.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "PKM Prices — Comparador de cartas Pokémon",
  description = "Compara precios de cartas Pokémon TCG entre TCGMatch.cl y TCGPlayer.com en tiempo real.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Fraunces:opsz,wght@9..144,600;9..144,700;9..144,800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-paper text-ink-900">
    <slot />
    <SearchLoader />
  </body>
</html>
