---
import { LEGENDARIES } from "../lib/legendaries.js";
interface Props {
  query?: string;
}
const { query = "" } = Astro.props;
---

<header
  class="sticky top-0 z-50 bg-paper/85 backdrop-blur-md border-b border-ink-200"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3 sm:py-0 sm:h-16 flex flex-col sm:grid sm:grid-cols-[1fr_minmax(0,640px)_1fr] sm:items-center gap-3 sm:gap-6">
    <!-- Brand -->
    <a href="/" class="flex items-center gap-2 shrink-0 sm:justify-self-start">
      <span class="w-7 h-7 rounded-full border-2 border-ink-900 relative grid place-items-center">
        <span class="absolute inset-x-0 top-1/2 h-[2px] bg-ink-900 -translate-y-1/2"></span>
        <span class="relative w-2 h-2 rounded-full bg-brand"></span>
      </span>
      <span class="font-display text-[17px] sm:text-[19px] font-bold leading-none tracking-tight whitespace-nowrap">
        LaTienda<span class="text-brand">TCG</span>
      </span>
    </a>

    <!-- Search + autocomplete -->
    <div class="search-wrap relative min-w-0 w-full">
      <form
        action="/"
        method="get"
        class="flex items-center bg-paper border border-ink-200 rounded-lg pl-3 sm:pl-4 pr-1 focus-within:border-brand/40 focus-within:ring-4 focus-within:ring-brand/8 transition"
      >
        <svg class="w-4 h-4 text-ink-400 mr-2 shrink-0" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
          <circle cx="9" cy="9" r="6"></circle>
          <path d="M15 15l-3.5-3.5"></path>
        </svg>
        <input
          id="search-input"
          type="text"
          name="q"
          value={query}
          placeholder="Buscar carta o código (ej. 022/086)"
          autocomplete="off"
          spellcheck="false"
          aria-label="Buscar carta"
          class="flex-1 min-w-0 bg-transparent border-none outline-none text-sm font-medium py-3 placeholder:text-ink-400"
        />
        <kbd class="hidden sm:inline-flex items-center text-[11px] font-mono text-ink-400 border border-ink-200 rounded px-1.5 py-0.5 mr-2">⌘ K</kbd>
        <button
          type="submit"
          aria-label="Buscar"
          class="shrink-0 bg-ink-900 text-paper text-xs font-bold tracking-wide px-3 sm:px-4 py-2 rounded-md hover:opacity-85 active:scale-95 transition"
        >
          <span class="hidden sm:inline">BUSCAR</span>
          <svg class="sm:hidden w-3.5 h-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2">
            <circle cx="9" cy="9" r="6"></circle>
            <path d="M15 15l-3.5-3.5"></path>
          </svg>
        </button>
      </form>
    </div>

    <!-- Dolar -->
    <div id="dolar-pill" class="hidden md:flex items-baseline gap-2 text-xs shrink-0 sm:justify-self-end md:mr-20">
      <span class="text-ink-400 tracking-wider font-semibold">USD / CLP</span>
      <span class="font-display font-bold text-base tabular text-ink-900" id="dolar-value">—</span>
      <span class="text-success font-semibold tabular" id="dolar-delta"></span>
    </div>

  </div>

  <!-- Pet picker: pegado al borde derecho del viewport, fuera del max-w-7xl
       para que en pantallas anchas (macbook) no quede flotando al centro. -->
  <div class="pet-picker-wrap absolute top-3 sm:top-1/2 right-3 sm:right-5 sm:-translate-y-1/2 z-10">
      <button
        id="pet-picker-btn"
        type="button"
        aria-label="Elegir Pokémon"
        aria-haspopup="true"
        aria-expanded="false"
        class="grid place-items-center w-11 h-11 rounded-full border border-ink-200 hover:border-brand/40 hover:bg-brand/5 transition"
      >
        <!-- Placeholder pokeball (visible cuando no hay selección) -->
        <span id="pet-empty" class="block w-4 h-4 rounded-full border-2 border-ink-900 relative">
          <span class="absolute inset-x-0 top-1/2 h-[1.5px] bg-ink-900 -translate-y-1/2"></span>
          <span class="absolute left-1/2 top-1/2 w-1 h-1 rounded-full bg-brand -translate-x-1/2 -translate-y-1/2"></span>
        </span>
        <!-- Sprite del pokemon elegido (visible cuando hay selección) -->
        <img id="pet-current" src="" alt="" class="hidden w-9 h-9 object-contain" style="image-rendering: pixelated;" />
      </button>

      <div
        id="pet-picker"
        role="dialog"
        aria-label="Elige tu Pokémon"
        class="hidden absolute top-full right-0 mt-2 w-[260px] bg-paper border border-ink-200 rounded-lg shadow-[0_16px_48px_-12px_rgba(11,11,11,0.18)] p-3 z-50"
      >
        <p class="text-[10px] font-bold tracking-[0.18em] uppercase text-ink-400 mb-2 px-1">
          Tu Pokémon
        </p>
        <div class="grid grid-cols-4 gap-1.5">
          {LEGENDARIES.map((p) => (
            <button
              type="button"
              data-pet={p.name}
              aria-label={p.alt}
              title={p.alt}
              class="pet-option grid place-items-center aspect-square rounded-md border border-transparent hover:border-brand/40 hover:bg-brand/5 transition"
            >
              <img
                src={`/sprites/${p.name}.gif`}
                alt={p.alt}
                loading="lazy"
                class="max-w-full max-h-full object-contain"
                style="image-rendering: pixelated;"
              />
            </button>
          ))}
        </div>
        <button
          type="button"
          data-pet=""
          class="pet-option mt-2 w-full text-[11px] font-semibold tracking-wide text-ink-500 hover:text-ink-900 border border-ink-200 rounded-md py-1.5 hover:bg-ink-100 transition"
        >
          Quitar Pokémon
        </button>
      </div>
  </div>
</header>

<script>
  // Fetch dolar rate y mostrar
  (async () => {
    try {
      const r = await fetch("/api/dolar");
      if (!r.ok) return;
      const { rate } = await r.json();
      (window as any).__dolarRate = rate;
      const v = document.getElementById("dolar-value");
      if (v) {
        v.textContent = "$ " + new Intl.NumberFormat("es-CL", { maximumFractionDigits: 2 }).format(rate);
      }
    } catch (_) {}
  })();


  // ────────────────────────────────────────────────────────────────────
  // Pet picker — selección persistida en localStorage
  // ────────────────────────────────────────────────────────────────────
  (() => {
    const STORAGE_KEY = "pkm-pet";
    const btn = document.getElementById("pet-picker-btn");
    const picker = document.getElementById("pet-picker");
    const empty = document.getElementById("pet-empty");
    const current = document.getElementById("pet-current") as HTMLImageElement | null;
    if (!btn || !picker || !empty || !current) return;

    function applyToButton(name: string | null) {
      if (name) {
        current!.src = `/sprites/${name}.gif`;
        current!.classList.remove("hidden");
        empty!.classList.add("hidden");
      } else {
        current!.removeAttribute("src");
        current!.classList.add("hidden");
        empty!.classList.remove("hidden");
      }
    }

    // Sincronizar estado inicial del botón con la selección persistida.
    try {
      applyToButton(localStorage.getItem(STORAGE_KEY));
    } catch {}

    function open() {
      picker!.classList.remove("hidden");
      btn!.setAttribute("aria-expanded", "true");
    }
    function close() {
      picker!.classList.add("hidden");
      btn!.setAttribute("aria-expanded", "false");
    }

    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      picker!.classList.contains("hidden") ? open() : close();
    });

    // Click en una opción → notifica a PetCursor y al botón
    picker.addEventListener("click", (e) => {
      const opt = (e.target as HTMLElement).closest(".pet-option") as HTMLElement | null;
      if (!opt) return;
      const name = opt.dataset.pet || null;
      applyToButton(name);
      window.dispatchEvent(new CustomEvent("pkm:pet-changed", { detail: { name } }));
      close();
    });

    // Click fuera del wrapper → cerrar
    document.addEventListener("click", (e) => {
      if (!(e.target as HTMLElement).closest(".pet-picker-wrap")) close();
    });

    // Esc cierra
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });
  })();
</script>
