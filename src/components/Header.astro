---
import { LEGENDARIES } from "../lib/legendaries.js";
interface Props {
  query?: string;
}
const { query = "" } = Astro.props;
---

<header
  class="sticky top-0 z-50 bg-paper/85 backdrop-blur-md border-b border-ink-200"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3 sm:py-0 sm:h-16 flex flex-col sm:grid sm:grid-cols-[1fr_minmax(0,640px)_1fr] sm:items-center gap-3 sm:gap-6">
    <!-- Brand -->
    <a href="/" class="flex items-center gap-2 shrink-0 sm:justify-self-start">
      <span class="w-7 h-7 rounded-full border-2 border-ink-900 relative grid place-items-center">
        <span class="absolute inset-x-0 top-1/2 h-[2px] bg-ink-900 -translate-y-1/2"></span>
        <span class="relative w-2 h-2 rounded-full bg-brand"></span>
      </span>
      <span class="font-display text-[17px] sm:text-[19px] font-bold leading-none tracking-tight whitespace-nowrap">
        LaTienda<span class="text-brand">TCG</span>
      </span>
    </a>

    <!-- Search + autocomplete -->
    <div class="search-wrap relative min-w-0 w-full">
      <form
        action="/"
        method="get"
        class="flex items-center bg-paper border border-ink-200 rounded-lg pl-3 sm:pl-4 pr-1 focus-within:border-brand/40 focus-within:ring-4 focus-within:ring-brand/8 transition"
      >
        <svg class="w-4 h-4 text-ink-400 mr-2 shrink-0" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
          <circle cx="9" cy="9" r="6"></circle>
          <path d="M15 15l-3.5-3.5"></path>
        </svg>
        <input
          id="search-input"
          type="text"
          name="q"
          value={query}
          placeholder="Buscar carta o código (ej. 022/086)"
          autocomplete="off"
          spellcheck="false"
          aria-label="Buscar carta"
          aria-autocomplete="list"
          aria-controls="autocomplete"
          aria-expanded="false"
          class="flex-1 min-w-0 bg-transparent border-none outline-none text-sm font-medium py-3 placeholder:text-ink-400"
        />
        <kbd class="hidden sm:inline-flex items-center text-[11px] font-mono text-ink-400 border border-ink-200 rounded px-1.5 py-0.5 mr-2">⌘ K</kbd>
        <button
          type="submit"
          aria-label="Buscar"
          class="shrink-0 bg-ink-900 text-paper text-xs font-bold tracking-wide px-3 sm:px-4 py-2 rounded-md hover:opacity-85 active:scale-95 transition"
        >
          <span class="hidden sm:inline">BUSCAR</span>
          <svg class="sm:hidden w-3.5 h-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2">
            <circle cx="9" cy="9" r="6"></circle>
            <path d="M15 15l-3.5-3.5"></path>
          </svg>
        </button>
      </form>

      <!-- Dropdown de autocomplete -->
      <div
        id="autocomplete"
        role="listbox"
        class="hidden absolute top-full left-0 right-0 mt-2 bg-paper border border-ink-200 rounded-lg shadow-[0_16px_48px_-12px_rgba(11,11,11,0.18)] overflow-hidden max-h-[70vh] overflow-y-auto"
      >
        <div data-loading class="hidden py-3 text-center text-[11px] tracking-widest font-bold uppercase text-ink-400">
          Buscando…
        </div>
        <div data-empty class="hidden p-5 text-center text-sm text-ink-400">
          Sin resultados
        </div>
        <ul data-results class="divide-y divide-ink-200"></ul>
      </div>
    </div>

    <!-- Dolar -->
    <div id="dolar-pill" class="hidden md:flex items-baseline gap-2 text-xs shrink-0 sm:justify-self-end">
      <span class="text-ink-400 tracking-wider font-semibold">USD / CLP</span>
      <span class="font-display font-bold text-base tabular text-ink-900" id="dolar-value">—</span>
      <span class="text-success font-semibold tabular" id="dolar-delta"></span>
    </div>

  </div>

  <!-- Pet picker: pegado al borde derecho del viewport, fuera del max-w-7xl
       para que en pantallas anchas (macbook) no quede flotando al centro. -->
  <div class="pet-picker-wrap absolute top-3 sm:top-1/2 right-3 sm:right-5 sm:-translate-y-1/2 z-10">
      <button
        id="pet-picker-btn"
        type="button"
        aria-label="Elegir Pokémon"
        aria-haspopup="true"
        aria-expanded="false"
        class="grid place-items-center w-11 h-11 rounded-full border border-ink-200 hover:border-brand/40 hover:bg-brand/5 transition"
      >
        <!-- Placeholder pokeball (visible cuando no hay selección) -->
        <span id="pet-empty" class="block w-4 h-4 rounded-full border-2 border-ink-900 relative">
          <span class="absolute inset-x-0 top-1/2 h-[1.5px] bg-ink-900 -translate-y-1/2"></span>
          <span class="absolute left-1/2 top-1/2 w-1 h-1 rounded-full bg-brand -translate-x-1/2 -translate-y-1/2"></span>
        </span>
        <!-- Sprite del pokemon elegido (visible cuando hay selección) -->
        <img id="pet-current" src="" alt="" class="hidden w-9 h-9 object-contain" style="image-rendering: pixelated;" />
      </button>

      <div
        id="pet-picker"
        role="dialog"
        aria-label="Elige tu Pokémon"
        class="hidden absolute top-full right-0 mt-2 w-[260px] bg-paper border border-ink-200 rounded-lg shadow-[0_16px_48px_-12px_rgba(11,11,11,0.18)] p-3 z-50"
      >
        <p class="text-[10px] font-bold tracking-[0.18em] uppercase text-ink-400 mb-2 px-1">
          Tu Pokémon
        </p>
        <div class="grid grid-cols-4 gap-1.5">
          {LEGENDARIES.map((p) => (
            <button
              type="button"
              data-pet={p.name}
              aria-label={p.alt}
              title={p.alt}
              class="pet-option grid place-items-center aspect-square rounded-md border border-transparent hover:border-brand/40 hover:bg-brand/5 transition"
            >
              <img
                src={`/sprites/${p.name}.gif`}
                alt={p.alt}
                loading="lazy"
                class="max-w-full max-h-full object-contain"
                style="image-rendering: pixelated;"
              />
            </button>
          ))}
        </div>
        <button
          type="button"
          data-pet=""
          class="pet-option mt-2 w-full text-[11px] font-semibold tracking-wide text-ink-500 hover:text-ink-900 border border-ink-200 rounded-md py-1.5 hover:bg-ink-100 transition"
        >
          Quitar Pokémon
        </button>
      </div>
  </div>
</header>

<script>
  // Fetch dolar rate y mostrar
  (async () => {
    try {
      const r = await fetch("/api/dolar");
      if (!r.ok) return;
      const { rate } = await r.json();
      (window as any).__dolarRate = rate;
      const v = document.getElementById("dolar-value");
      if (v) {
        v.textContent = "$ " + new Intl.NumberFormat("es-CL", { maximumFractionDigits: 2 }).format(rate);
      }
    } catch (_) {}
  })();

  // ────────────────────────────────────────────────────────────────────
  // Autocomplete del buscador
  // ────────────────────────────────────────────────────────────────────
  (() => {
    const input = document.getElementById("search-input") as HTMLInputElement | null;
    const dropdown = document.getElementById("autocomplete");
    if (!input || !dropdown) return;

    const form = input.closest("form")!;
    const listEl = dropdown.querySelector("[data-results]") as HTMLUListElement;
    const emptyEl = dropdown.querySelector("[data-empty]") as HTMLElement;
    const loadingEl = dropdown.querySelector("[data-loading]") as HTMLElement;

    const fmtUSD = (n: number) =>
      new Intl.NumberFormat("en-US", { style: "currency", currency: "USD", minimumFractionDigits: 2 }).format(n);
    const escapeHtml = (s: string) =>
      String(s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");

    let lastCards: any[] = [];
    let activeIdx = -1;
    let abortCtrl: AbortController | null = null;
    let debounceTimer: ReturnType<typeof setTimeout> | null = null;

    function setExpanded(v: boolean) {
      input!.setAttribute("aria-expanded", String(v));
    }

    function openDropdown() {
      dropdown!.classList.remove("hidden");
      setExpanded(true);
    }

    function closeDropdown() {
      dropdown!.classList.add("hidden");
      setExpanded(false);
      activeIdx = -1;
    }

    function showLoading() {
      emptyEl.classList.add("hidden");
      loadingEl.classList.remove("hidden");
      openDropdown();
    }
    function hideLoading() { loadingEl.classList.add("hidden"); }

    function showEmpty() {
      listEl.innerHTML = "";
      lastCards = [];
      activeIdx = -1;
      hideLoading();
      emptyEl.classList.remove("hidden");
      openDropdown();
    }

    function renderRows(cards: any[]) {
      lastCards = cards.slice(0, 6);
      activeIdx = -1;
      hideLoading();
      emptyEl.classList.add("hidden");
      listEl.innerHTML = lastCards.map((c, i) => {
        const img = c.images?.small || "";
        const total = c.setPrintedTotal || c.setTotal;
        const codeStr = c.number ? (total ? `#${c.number}/${total}` : `#${c.number}`) : "";
        const tcgp = typeof c.tcgpMarket === "number" && c.tcgpMarket > 0 ? fmtUSD(c.tcgpMarket) : "";
        return `
          <li role="option" data-idx="${i}" class="ac-row cursor-pointer flex items-center gap-3 px-3 py-2 hover:bg-ink-100 transition">
            <div class="w-10 h-14 shrink-0 bg-ink-100 rounded overflow-hidden grid place-items-center">
              ${img ? `<img src="${escapeHtml(img)}" alt="" loading="lazy" class="w-full h-full object-contain"/>` : ""}
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-sm font-semibold text-ink-900 truncate">${escapeHtml(c.name || "")}</p>
              <p class="text-[11px] text-ink-400 truncate mt-0.5">
                ${escapeHtml(c.set || "")}${codeStr ? ` · ${escapeHtml(codeStr)}` : ""}
              </p>
            </div>
            ${tcgp ? `<p class="shrink-0 font-display text-sm font-bold tabular text-ink-900">${tcgp}</p>` : ""}
          </li>
        `;
      }).join("");
      openDropdown();
    }

    function setActive(idx: number) {
      const rows = Array.from(listEl.querySelectorAll(".ac-row")) as HTMLElement[];
      rows.forEach((r, i) => {
        if (i === idx) r.classList.add("bg-brand/8");
        else r.classList.remove("bg-brand/8");
      });
      activeIdx = idx;
      if (idx >= 0 && rows[idx]) rows[idx].scrollIntoView({ block: "nearest" });
    }

    async function runSearch(q: string) {
      if (abortCtrl) abortCtrl.abort();
      abortCtrl = new AbortController();
      showLoading();
      try {
        const r = await fetch("/api/cards?name=" + encodeURIComponent(q), { signal: abortCtrl.signal });
        if (!r.ok) { showEmpty(); return; }
        const data = await r.json();
        const cards = (data?.cards || []) as any[];
        if (!cards.length) showEmpty();
        else renderRows(cards);
      } catch (e: any) {
        if (e?.name === "AbortError") return;
        showEmpty();
      }
    }

    input.addEventListener("input", () => {
      const q = input.value.trim();
      if (debounceTimer) clearTimeout(debounceTimer);
      if (q.length < 2) {
        closeDropdown();
        if (abortCtrl) abortCtrl.abort();
        return;
      }
      debounceTimer = setTimeout(() => runSearch(q), 250);
    });

    // Re-abrir al focus si hay resultados previos.
    input.addEventListener("focus", () => {
      if (lastCards.length && input.value.trim().length >= 2) openDropdown();
    });

    // Click en una fila → abre modal directo (sin navegar).
    listEl.addEventListener("click", (e) => {
      const row = (e.target as HTMLElement).closest(".ac-row") as HTMLElement | null;
      if (!row) return;
      const idx = parseInt(row.dataset.idx || "-1", 10);
      const card = lastCards[idx];
      if (!card) return;
      closeDropdown();
      input.blur();
      window.dispatchEvent(new CustomEvent("pkm:open-card", { detail: card }));
    });

    // Keyboard: flechas / Enter / Esc
    input.addEventListener("keydown", (e) => {
      const isOpen = !dropdown.classList.contains("hidden");
      if (e.key === "ArrowDown" && isOpen && lastCards.length) {
        e.preventDefault();
        setActive(Math.min(activeIdx + 1, lastCards.length - 1));
      } else if (e.key === "ArrowUp" && isOpen && lastCards.length) {
        e.preventDefault();
        setActive(Math.max(activeIdx - 1, 0));
      } else if (e.key === "Enter") {
        if (isOpen && activeIdx >= 0 && lastCards[activeIdx]) {
          // Selección con teclado → abre modal y previene submit
          e.preventDefault();
          const card = lastCards[activeIdx];
          closeDropdown();
          input.blur();
          window.dispatchEvent(new CustomEvent("pkm:open-card", { detail: card }));
        }
        // Sin item activo → deja submitear (SearchLoader se encarga del resto)
      } else if (e.key === "Escape") {
        closeDropdown();
      }
    });

    // Click fuera del wrapper → cerrar
    document.addEventListener("click", (e) => {
      const wrap = (e.target as HTMLElement).closest(".search-wrap");
      if (!wrap) closeDropdown();
    });

    // Cuando se envía el form (Enter sin item activo o botón), cerramos
    form.addEventListener("submit", () => closeDropdown());
  })();

  // ────────────────────────────────────────────────────────────────────
  // Pet picker — selección persistida en localStorage
  // ────────────────────────────────────────────────────────────────────
  (() => {
    const STORAGE_KEY = "pkm-pet";
    const btn = document.getElementById("pet-picker-btn");
    const picker = document.getElementById("pet-picker");
    const empty = document.getElementById("pet-empty");
    const current = document.getElementById("pet-current") as HTMLImageElement | null;
    if (!btn || !picker || !empty || !current) return;

    function applyToButton(name: string | null) {
      if (name) {
        current!.src = `/sprites/${name}.gif`;
        current!.classList.remove("hidden");
        empty!.classList.add("hidden");
      } else {
        current!.removeAttribute("src");
        current!.classList.add("hidden");
        empty!.classList.remove("hidden");
      }
    }

    // Sincronizar estado inicial del botón con la selección persistida.
    try {
      applyToButton(localStorage.getItem(STORAGE_KEY));
    } catch {}

    function open() {
      picker!.classList.remove("hidden");
      btn!.setAttribute("aria-expanded", "true");
    }
    function close() {
      picker!.classList.add("hidden");
      btn!.setAttribute("aria-expanded", "false");
    }

    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      picker!.classList.contains("hidden") ? open() : close();
    });

    // Click en una opción → notifica a PetCursor y al botón
    picker.addEventListener("click", (e) => {
      const opt = (e.target as HTMLElement).closest(".pet-option") as HTMLElement | null;
      if (!opt) return;
      const name = opt.dataset.pet || null;
      applyToButton(name);
      window.dispatchEvent(new CustomEvent("pkm:pet-changed", { detail: { name } }));
      close();
    });

    // Click fuera del wrapper → cerrar
    document.addEventListener("click", (e) => {
      if (!(e.target as HTMLElement).closest(".pet-picker-wrap")) close();
    });

    // Esc cierra
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });
  })();
</script>
