---
// Loader que aparece al hacer submit en el buscador.
// 8 legendarios (GIFs animados de PokémonDB Black/White) caminan
// horizontalmente sobre la página difuminada. Sin círculo de bosque.
import { LEGENDARIES as WALKERS } from "../lib/legendaries.js";
---

<div
  id="search-loader"
  role="dialog"
  aria-modal="true"
  aria-labelledby="search-loader-title"
  class="search-loader fixed inset-0 z-[200]"
>
  {/* Backdrop: blur sobre la página, sin tapar con color sólido */}
  <div class="absolute inset-0 backdrop-blur-md bg-paper/55"></div>

  {/* Parade horizontal — cruza el viewport completo, no limitada al texto.
      Posicionado justo arriba del título para no solaparse. */}
  <div class="legend-parade fixed inset-x-0 top-[calc(50%-200px)] h-24 pointer-events-none">
    {WALKERS.map((w, i) => (
      <img
        class={`walker walker-${i + 1}`}
        src={`/sprites/${w.name}.gif`}
        alt={w.alt}
        loading="eager"
        decoding="async"
      />
    ))}
  </div>

  {/* Texto centrado */}
  <div class="absolute inset-0 grid place-items-center px-6">
    <div class="text-center">
      <p id="search-loader-title" class="font-display text-2xl sm:text-3xl font-bold tracking-tight text-ink-900">
        Buscando <span class="text-brand">carta</span>
      </p>

      <div class="mt-4 inline-flex items-center gap-1.5">
        <span class="search-dot"></span>
        <span class="search-dot"></span>
        <span class="search-dot"></span>
      </div>
    </div>
  </div>
</div>

<style>
  .search-loader { display: none; }
  .search-loader.is-visible { display: block; }

  /* Parade horizontal — 8 GIFs animados que cruzan el área de izquierda a derecha.
     Para que el sprite "mire hacia la derecha" aplicamos un sutil tilt 3D
     (rotateY hacia la derecha) que sugiere que avanza en esa dirección, más
     una leve rotación adelante (rotate -3deg) que da motion lean.
     Animamos `left` (no transform) para no pelearnos con el transform de
     orientación. */
  .walker {
    position: absolute;
    height: 72px;
    width: auto;
    image-rendering: pixelated;
    left: -180px;
    /* Orientación hacia la derecha: tilt 3D + leve forward lean */
    transform: perspective(180px) rotateY(-22deg) rotate(-3deg);
    transform-origin: center bottom;
  }
  .walker-3 { height: 80px; }
  .walker-5 { height: 82px; } /* Lugia */
  .walker-6 { height: 82px; } /* Ho-Oh */
  .walker-8 { height: 86px; } /* Rayquaza */

  .search-loader.is-visible .walker {
    animation-name: walk-across;
    animation-duration: 14s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
  }

  .walker-1 { bottom:  8px; }
  .walker-2 { bottom:  0px; }
  .walker-3 { bottom: 10px; }
  .walker-4 { bottom:  2px; }
  .walker-5 { bottom:  6px; }
  .walker-6 { bottom: 12px; }
  .walker-7 { bottom:  4px; }
  .walker-8 { bottom:  0px; }
  /* 8 walkers escalonados sobre 14s = 1.75s entre cada uno */
  .search-loader.is-visible .walker-1 { animation-delay:   0s;    }
  .search-loader.is-visible .walker-2 { animation-delay:  -1.75s; }
  .search-loader.is-visible .walker-3 { animation-delay:  -3.5s;  }
  .search-loader.is-visible .walker-4 { animation-delay:  -5.25s; }
  .search-loader.is-visible .walker-5 { animation-delay:  -7s;    }
  .search-loader.is-visible .walker-6 { animation-delay:  -8.75s; }
  .search-loader.is-visible .walker-7 { animation-delay: -10.5s;  }
  .search-loader.is-visible .walker-8 { animation-delay: -12.25s; }

  @keyframes walk-across {
    from { left: -180px; }
    to   { left: calc(100vw + 40px); }
  }

  .search-dot {
    width: 7px;
    height: 7px;
    border-radius: 9999px;
    background: var(--color-brand, #1d4ed8);
    opacity: 0.4;
    animation: dot-pulse 1.2s ease-in-out infinite;
  }
  .search-dot:nth-child(2) { animation-delay: 0.15s; }
  .search-dot:nth-child(3) { animation-delay: 0.3s; }

  @keyframes dot-pulse {
    0%, 100% { opacity: 0.4; transform: scale(0.85); }
    50% { opacity: 1; transform: scale(1.2); }
  }

  @media (prefers-reduced-motion: reduce) {
    .search-loader.is-visible .walker {
      animation: none;
    }
    .walker-1 { left:  4%; }
    .walker-2 { left: 16%; }
    .walker-3 { left: 28%; }
    .walker-4 { left: 40%; }
    .walker-5 { left: 52%; }
    .walker-6 { left: 64%; }
    .walker-7 { left: 76%; }
    .walker-8 { left: 88%; }
    .search-dot { animation: none; opacity: 0.7; }
  }
</style>

<script>
  const loader = document.getElementById("search-loader");
  if (loader) {
    document.querySelectorAll<HTMLFormElement>('form[action="/"]').forEach((form) => {
      form.addEventListener("submit", (e) => {
        const input = form.querySelector<HTMLInputElement>('input[name="q"]');
        const q = input?.value?.trim() ?? "";
        if (q.length < 2) return;
        loader.classList.add("is-visible");
        setTimeout(() => loader.classList.remove("is-visible"), 8000);
      });
    });

    // Cuando aterrizamos en la nueva página, si hay resultados esperamos que
    // las primeras imágenes de las cartas terminen de bajar antes de ocultar
    // el loader — evita ver el layout vacío mientras el CDN sirve las cartas.
    window.addEventListener("pageshow", async () => {
      const cardImgs = Array.from(
        document.querySelectorAll<HTMLImageElement>("[data-card-id] img"),
      ).slice(0, 10);

      if (!cardImgs.length) {
        loader.classList.remove("is-visible");
        return;
      }

      loader.classList.add("is-visible");

      const pending = cardImgs
        .filter((img) => !img.complete)
        .map(
          (img) =>
            new Promise<void>((resolve) => {
              img.addEventListener("load", () => resolve(), { once: true });
              img.addEventListener("error", () => resolve(), { once: true });
            }),
        );

      await Promise.race([
        Promise.all(pending),
        new Promise<void>((resolve) => setTimeout(resolve, 4000)),
      ]);

      loader.classList.remove("is-visible");
    });
  }
</script>
